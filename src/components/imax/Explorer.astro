---
import { FORMATS, RATIO_NAMES, DEFAULT_GHOST_ID } from './formats';

// Server-rendered initial state, so the panel has real content before any JS
// runs (no empty-dash flash, and the page still reads with JS disabled).
const initial = FORMATS[0];
const initialRatio = RATIO_NAMES.find(
  (x) => Math.abs(x.r - initial.w / initial.h) < 0.012,
);
const fmt = (n: number) => n.toLocaleString('en-US');
const initialMP = ((initial.w * initial.h) / 1e6).toFixed(0);

// Group once here rather than in the client script — the selector's <optgroup>
// structure is static, so it belongs in the HTML.
const categories = [...new Set(FORMATS.map((f) => f.cat))];
---

<div class="max-w-7xl mx-auto w-full px-4 sm:px-6 py-6 grid grid-cols-1 lg:grid-cols-[340px_minmax(0,1fr)] gap-6">

  <!-- ── Controls + specs ───────────────────────────────── -->
  <section class="space-y-4">

    <div class="bg-zinc-900/60 border border-zinc-800 rounded-lg p-4">
      <label for="formatSelect" class="block text-[11px] uppercase tracking-widest text-zinc-500 mb-2">Format</label>
      <select id="formatSelect"
        class="w-full bg-zinc-950 border border-zinc-700 rounded px-3 py-2.5 text-sm text-zinc-100
               focus:outline-none focus:ring-2 focus:ring-cyan-500/60 focus:border-cyan-500 transition">
        {categories.map((cat) => (
          <optgroup label={cat}>
            {FORMATS.filter((f) => f.cat === cat).map((f) => (
              <option value={f.id}>{f.name}</option>
            ))}
          </optgroup>
        ))}
      </select>

      <div class="mt-4 pt-4 border-t border-zinc-800">
        <label class="flex items-center gap-2.5 cursor-pointer select-none">
          <input type="checkbox" id="customToggle" class="peer sr-only" />
          <span class="w-9 h-5 rounded-full bg-zinc-700 peer-checked:bg-cyan-500 transition relative
                       after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4
                       after:rounded-full after:bg-white after:transition peer-checked:after:translate-x-4"></span>
          <span class="text-sm text-zinc-300">Custom dimensions</span>
        </label>

        <div id="customFields" class="hidden mt-3 grid grid-cols-2 gap-2">
          <div>
            <label for="customW" class="block text-[10px] uppercase tracking-wider text-zinc-500 mb-1">Width px</label>
            <input id="customW" type="number" min="1" value="2560"
              class="w-full bg-zinc-950 border border-zinc-700 rounded px-2.5 py-2 text-sm font-mono
                     focus:outline-none focus:ring-2 focus:ring-amber-500/60 focus:border-amber-500 transition" />
          </div>
          <div>
            <label for="customH" class="block text-[10px] uppercase tracking-wider text-zinc-500 mb-1">Height px</label>
            <input id="customH" type="number" min="1" value="1080"
              class="w-full bg-zinc-950 border border-zinc-700 rounded px-2.5 py-2 text-sm font-mono
                     focus:outline-none focus:ring-2 focus:ring-amber-500/60 focus:border-amber-500 transition" />
          </div>
        </div>
      </div>
    </div>

    <!-- Details -->
    <div class="bg-zinc-900/60 border border-zinc-800 rounded-lg overflow-hidden">
      <div class="px-4 py-3 border-b border-zinc-800">
        <h2 id="dName" class="text-base font-semibold text-zinc-100 leading-snug">{initial.name}</h2>
        <p id="dType" class="text-[11px] uppercase tracking-widest text-cyan-400 mt-0.5">{initial.cat} · {initial.note}</p>
      </div>

      <dl class="divide-y divide-zinc-800/80 text-sm">
        <div class="px-4 py-3 flex justify-between gap-4">
          <dt class="text-zinc-500">Aspect ratio</dt>
          <dd class="text-right">
            <span id="dRatio" class="font-mono text-cyan-300">{initialRatio?.label}</span>
            <span id="dRatioFrac" class="block text-[11px] text-zinc-500 font-mono">{initialRatio?.frac}</span>
          </dd>
        </div>
        <div class="px-4 py-3 flex justify-between gap-4">
          <dt class="text-zinc-500">Resolution</dt>
          <dd id="dRes" class="font-mono text-zinc-200 text-right">{fmt(initial.w)} × {fmt(initial.h)}</dd>
        </div>
        <div class="px-4 py-3 flex justify-between gap-4">
          <dt class="text-zinc-500">Pixel count</dt>
          <dd id="dPixels" class="font-mono text-amber-300 text-right">{initialMP} MP</dd>
        </div>
      </dl>

      <div class="px-4 py-3 border-t border-zinc-800 bg-zinc-950/40">
        <p class="text-[11px] uppercase tracking-widest text-zinc-500 mb-1.5">Use case</p>
        <p id="dUse" class="text-[13px] leading-relaxed text-zinc-400">{initial.use}</p>
      </div>
    </div>

    <!-- Comparison -->
    <div class="bg-zinc-900/60 border border-zinc-800 rounded-lg p-4">
      <label for="ghostSelect" class="block text-[11px] uppercase tracking-widest text-zinc-500 mb-2">
        Compare against
      </label>
      <select id="ghostSelect"
        class="w-full bg-zinc-950 border border-zinc-700 rounded px-3 py-2.5 text-sm text-zinc-100
               focus:outline-none focus:ring-2 focus:ring-amber-500/60 focus:border-amber-500 transition">
        <option value="">None</option>
        {categories.map((cat) => (
          <optgroup label={cat}>
            {FORMATS.filter((f) => f.cat === cat).map((f) => (
              <option value={f.id} selected={f.id === DEFAULT_GHOST_ID}>{f.name}</option>
            ))}
          </optgroup>
        ))}
      </select>

      <label class="flex items-center gap-2.5 mt-3 cursor-pointer select-none">
        <input type="checkbox" id="scaleToggle" checked class="peer sr-only" />
        <span class="w-9 h-5 rounded-full bg-zinc-700 peer-checked:bg-amber-500 transition relative
                     after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4
                     after:rounded-full after:bg-white after:transition peer-checked:after:translate-x-4"></span>
        <span class="text-sm text-zinc-300">Show human for scale</span>
      </label>
    </div>
  </section>

  <!-- ── Stage ──────────────────────────────────────────── -->
  <section class="min-w-0">
    <div class="bg-zinc-900/40 border border-zinc-800 rounded-lg p-3 sm:p-5">
      <div class="flex items-center justify-between mb-3 text-[11px] uppercase tracking-widest text-zinc-500">
        <span>Master screen canvas</span>
        <span id="stageBadge" class="text-cyan-400 font-mono normal-case tracking-normal">{initialRatio?.label}</span>
      </div>

      <div id="stage"
        class="stage-grid relative w-full rounded bg-zinc-950 border border-zinc-800 overflow-hidden
               h-[46vh] min-h-[280px] sm:h-[58vh] grid place-items-center">

        <div id="ghostFrame"
          class="frame-anim absolute border-2 border-dashed border-amber-400/50 rounded-sm pointer-events-none hidden">
          <span id="ghostLabel" class="absolute -top-5 left-0 text-[10px] font-mono text-amber-400/80 whitespace-nowrap"></span>
        </div>

        <div id="frame"
          class="frame-anim relative bg-linear-to-br from-cyan-500/10 to-cyan-500/[.03]
                 border-2 border-cyan-400 rounded-sm shadow-[0_0_40px_-8px_rgba(34,211,238,.55)]">
          <span id="frameLabel" class="absolute -top-5 left-0 text-[10px] font-mono text-cyan-300 whitespace-nowrap"></span>
          <span id="frameDims" class="absolute -bottom-5 right-0 text-[10px] font-mono text-zinc-500 whitespace-nowrap"></span>
        </div>

        <svg id="human" viewBox="0 0 40 100"
          class="absolute bottom-0 left-4 h-[16%] opacity-40 text-zinc-400" fill="currentColor" aria-hidden="true">
          <circle cx="20" cy="11" r="9" />
          <path d="M20 22c-9 0-15 6-15 15v28h7v35h6V70h4v30h6V65h7V37c0-9-6-15-15-15z" />
        </svg>
      </div>

      <p class="mt-3 text-[11px] text-zinc-600 leading-relaxed">
        Frames share a constant <span class="text-zinc-400 font-mono">screen area</span>, not a constant width — so the
        tall 1.43:1 IMAX frame reads honestly against 2.39:1 Scope, the way a real theatre trades height for width.
      </p>
    </div>
  </section>
</div>

<style>
  .stage-grid {
    background-image:
      linear-gradient(to right,  rgba(255,255,255,.045) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,.045) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .frame-anim {
    transition: width .45s cubic-bezier(.4,0,.2,1), height .45s cubic-bezier(.4,0,.2,1);
  }
</style>

<!--
  `define:vars` serializes the dataset into an INLINE script — so this block is
  plain JS with no imports and no bundling. Keep it self-contained.
-->
<script is:inline define:vars={{ FORMATS, RATIO_NAMES, DEFAULT_GHOST_ID }}>
  const $ = (id) => document.getElementById(id);
  const gcd = (a, b) => (b ? gcd(b, a % b) : a);
  const fmtNum = (n) => n.toLocaleString('en-US');

  function ratioInfo(w, h) {
    const r = w / h;
    const hit = RATIO_NAMES.find((x) => Math.abs(x.r - r) < 0.012);
    if (hit) return { decimal: hit.label, frac: hit.frac };
    const g = gcd(w, h);
    const rw = w / g, rh = h / g;
    return { decimal: `${r.toFixed(2)}:1`, frac: rw <= 400 && rh <= 400 ? `${rw}:${rh}` : '—' };
  }

  function megapixels(w, h) {
    const mp = (w * h) / 1e6;
    if (mp >= 100) return `${mp.toFixed(0)} MP`;
    if (mp >= 10) return `${mp.toFixed(1)} MP`;
    return `${mp.toFixed(2)} MP`;
  }

  let current = FORMATS[0];
  let ghost = FORMATS.find((f) => f.id === DEFAULT_GHOST_ID) ?? null;

  /**
   * Size a frame to a shared AREA budget rather than a shared width.
   * Fitting to width would make 1.43:1 look small and 2.39:1 look enormous,
   * which is the opposite of the truth.
   */
  function sizeFrame(el, w, h, areaFactor) {
    const stage = $('stage');
    const maxW = stage.clientWidth - 48;   // padding for floating labels
    const maxH = stage.clientHeight - 56;
    const ratio = w / h;

    let fw = maxW, fh = fw / ratio;
    if (fh > maxH) { fh = maxH; fw = fh * ratio; }

    const scale = Math.min(1, Math.sqrt((maxW * maxH * areaFactor) / (fw * fh)));
    el.style.width = `${Math.round(fw * scale)}px`;
    el.style.height = `${Math.round(fh * scale)}px`;
  }

  function render() {
    const { w, h } = current;
    const info = ratioInfo(w, h);

    $('dName').textContent = current.name;
    $('dType').textContent = current.cat + (current.note ? ' · ' + current.note : '');
    $('dRatio').textContent = info.decimal;
    $('dRatioFrac').textContent = info.frac;
    $('dRes').textContent = `${fmtNum(w)} × ${fmtNum(h)}`;
    $('dPixels').textContent = megapixels(w, h);
    $('dUse').textContent = current.use;
    $('stageBadge').textContent = info.decimal;

    sizeFrame($('frame'), w, h, 0.62);
    $('frameLabel').textContent = current.name;
    $('frameDims').textContent = `${fmtNum(w)} × ${fmtNum(h)} · ${megapixels(w, h)}`;

    const gf = $('ghostFrame');
    if (ghost && ghost.id !== current.id) {
      gf.classList.remove('hidden');
      sizeFrame(gf, ghost.w, ghost.h, 0.62);
      $('ghostLabel').textContent = `${ghost.name} · ${ratioInfo(ghost.w, ghost.h).decimal}`;
    } else {
      gf.classList.add('hidden');
    }
  }

  function applyCustom() {
    const w = Math.max(1, parseInt($('customW').value, 10) || 1);
    const h = Math.max(1, parseInt($('customH').value, 10) || 1);
    current = {
      id: 'custom', cat: 'Custom', name: 'Custom Format', w, h, note: 'user defined',
      use: `User-defined container at ${fmtNum(w)} × ${fmtNum(h)}. Aspect ratio is derived live from the dimensions you enter.`,
    };
    render();
  }

  $('formatSelect').addEventListener('change', (e) => {
    current = FORMATS.find((f) => f.id === e.target.value);
    $('customToggle').checked = false;
    $('customFields').classList.add('hidden');
    render();
  });

  $('ghostSelect').addEventListener('change', (e) => {
    ghost = FORMATS.find((f) => f.id === e.target.value) ?? null;
    render();
  });

  $('customToggle').addEventListener('change', (e) => {
    $('customFields').classList.toggle('hidden', !e.target.checked);
    if (e.target.checked) applyCustom();
    else { current = FORMATS.find((f) => f.id === $('formatSelect').value); render(); }
  });

  $('customW').addEventListener('input', () => { if ($('customToggle').checked) applyCustom(); });
  $('customH').addEventListener('input', () => { if ($('customToggle').checked) applyCustom(); });
  $('scaleToggle').addEventListener('change', (e) => $('human').classList.toggle('hidden', !e.target.checked));

  new ResizeObserver(render).observe($('stage'));
  render();
</script>
