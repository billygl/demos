---
import Scene from './Scene.astro';
import { getFormats, getFacts, SOURCE_RATIO, DEFAULT_FORMAT_ID, cropFractions, detailFraction } from './formats';
import { t, type Lang } from '../../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;

const RELEASE_FORMATS = getFormats(lang);
const FACTS = getFacts(lang);
const L = t(lang);

// Strings the client script needs at runtime, serialized alongside the data.
const STR = {
  cutNothing: L.cutNothing,
  loupeFilm: L.loupeFilm('{px}'),
  loupeSame: L.loupeSame,
  loupeCompare: L.loupeCompare,
  loupeDigital: L.loupeDigital('{px}'),
  detailOnly: L.detailOnly(0).replace('0', '{d}'),
  cutVertical: L.cutVertical,
  cutHorizontal: L.cutHorizontal,
  fullNegative: L.fullNegative,
  lossTag: L.lossTag(0, 0).replace('0', '{p}').replace('0', '{d}'),
};

// Two INDEPENDENT losses. Framing is what the crop removes; detail is what the
// projector can resolve. IMAX with Laser keeps 100% of the first and ~23% of
// the second, so reporting only "kept" made it read as lossless.
const rows = RELEASE_FORMATS.map((f) => {
  const c = cropFractions(f.ratio);
  return { ...f, kept: c.width * c.height, detail: detailFraction(f.detailPx) };
});

const initial = rows.find((r) => r.id === DEFAULT_FORMAT_ID)!;
const categories = [...new Set(rows.map((r) => r.cat))];
const pct = (n: number) => Math.round(n * 100);
---

{/*
  One viewport, no page scroll. Every row is shrink-0 except the stage, which
  takes flex-1 and min-h-0 so it absorbs whatever height is left over.
  `min-h-0` is load-bearing: without it a flex child refuses to shrink below
  its content and the page scrolls again.

  The old two-mode toggle is gone. Showing the full negative with the discarded
  bands hatched already communicates the projected frame — the amber outline IS
  "as you'd see it", so a second mode was saying the same thing twice.
*/}
<main class="flex-1 min-h-0 flex flex-col lg:grid lg:grid-cols-[300px_minmax(0,1fr)]
             gap-2 sm:gap-4 px-2 sm:px-5 py-2 sm:py-4">

  {/* ── MOBILE: chip switcher ───────────────────────────────────── */}
  <div class="lg:hidden shrink-0">
    <div id="chipStrip"
         class="flex gap-1.5 overflow-x-auto no-scrollbar snap-x snap-mandatory pb-0.5"
         role="radiogroup" aria-label={L.formatGroup}>
      {rows.map((r) => (
        <button type="button" role="radio"
          aria-checked={r.id === initial.id ? 'true' : 'false'}
          data-format={r.id}
          class="format-btn chip snap-start shrink-0 px-3 py-1.5 rounded-full border border-zinc-700
                 bg-zinc-900 text-[12px] whitespace-nowrap transition cursor-pointer">
          <span class="text-zinc-300">{r.ratioLabel}</span>
          <span class="ml-1.5 font-mono text-[10px] text-zinc-500 tabular-nums">{pct(r.kept)}/{pct(r.detail)}</span>
        </button>
      ))}
    </div>
  </div>

  {/* ── DESKTOP: sidebar ────────────────────────────────────────── */}
  <aside class="hidden lg:flex flex-col min-h-0 gap-3">
    <div class="bg-zinc-900/60 border border-zinc-800 rounded-lg p-3 flex-1 min-h-0 flex flex-col">
      <p class="text-[10px] uppercase tracking-widest text-zinc-500 mb-2 shrink-0">{L.howWatching}</p>
      <div class="space-y-3 overflow-y-auto min-h-0" role="radiogroup" aria-label={L.formatGroup}>
        {categories.map((cat) => (
          <div>
            <p class="text-[9px] uppercase tracking-widest text-zinc-600 mb-1">{cat}</p>
            <div class="space-y-0.5">
              {rows.filter((r) => r.cat === cat).map((r) => (
                <button type="button" role="radio"
                  aria-checked={r.id === initial.id ? 'true' : 'false'}
                  data-format={r.id}
                  class="format-btn w-full text-left px-2 py-1.5 rounded border border-transparent
                         hover:bg-zinc-800/50 hover:border-zinc-700 transition group cursor-pointer">
                  <span class="flex items-baseline justify-between gap-2">
                    <span class="text-[12px] text-zinc-300 group-hover:text-zinc-100 truncate">{r.name}</span>
                    <span class="text-[10px] font-mono text-zinc-500 shrink-0">{r.ratioLabel}</span>
                  </span>
                  <span class="mt-1 block space-y-0.5">
                    <span class="flex items-center gap-2">
                      <span class="flex-1 h-1 rounded-full bg-zinc-800 overflow-hidden">
                        <span class="bar block h-full rounded-full transition-all duration-500"
                              style={`width:${pct(r.kept)}%`}></span>
                      </span>
                      <span class="text-[9px] font-mono text-zinc-500 w-14 text-right tabular-nums">
                        {pct(r.kept)}% {L.framing.toLowerCase().slice(0, 4)}
                      </span>
                    </span>
                    <span class="flex items-center gap-2">
                      <span class="flex-1 h-1 rounded-full bg-zinc-800 overflow-hidden">
                        <span class="bar-detail block h-full rounded-full transition-all duration-500"
                              style={`width:${pct(r.detail)}%`}></span>
                      </span>
                      <span class="text-[9px] font-mono text-zinc-500 w-14 text-right tabular-nums">
                        {pct(r.detail)}% {L.detail.toLowerCase().slice(0, 4)}
                      </span>
                    </span>
                  </span>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <button type="button" id="whyBtnDesktop"
      class="shrink-0 w-full px-3 py-2 rounded-lg border border-zinc-800 bg-zinc-900/60
             text-[12px] text-zinc-400 hover:text-cyan-300 hover:border-cyan-400/40 transition cursor-pointer">
      {L.whyCta}
    </button>
  </aside>

  {/* ── Stage column ────────────────────────────────────────────── */}
  <section class="flex-1 min-h-0 flex flex-col gap-2">

    <div class="shrink-0 flex items-center justify-between gap-3">
      <div class="min-w-0">
        <h2 id="fName" class="text-[13px] sm:text-sm font-semibold text-zinc-100 truncate">{initial.name}</h2>
        <p id="fVenue" class="text-[11px] text-zinc-500 truncate">{initial.venue}</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span id="fRatio" class="text-[13px] font-mono text-cyan-400">{initial.ratioLabel}</span>
        <button type="button" id="whyBtnMobile" aria-label={L.whyTitle}
          class="lg:hidden w-7 h-7 rounded-full border border-zinc-700 text-zinc-400 text-[12px]
                 grid place-items-center cursor-pointer">i</button>
      </div>
    </div>

    {/* The only element allowed to grow. */}
    <div class="relative flex-1 min-h-0">
      <div id="stage"
           class="absolute inset-0 touch-pan-y
                  bg-zinc-950 border border-zinc-800 rounded overflow-hidden">
        {/*
          Centred by absolute + transform rather than grid/flex centring.
          The viewport's size is written from JS in px, and a centring scheme
          that depends on the parent's content box drifts if that box is
          measured before layout settles. This is immune to that.
        */}
        <div id="viewport"
             class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 overflow-hidden ring-2 ring-cyan-400/70">
          <div id="negativeBox" class="absolute top-0 left-0"><Scene /></div>
          <div id="bandTop"    class="band absolute left-0 top-0 w-full"></div>
          <div id="bandBottom" class="band absolute left-0 bottom-0 w-full"></div>
          <div id="bandLeft"   class="band absolute top-0 left-0 h-full"></div>
          <div id="bandRight"  class="band absolute top-0 right-0 h-full"></div>
          <div id="focusMark"
               class="absolute w-7 h-7 -ml-3.5 -mt-3.5 rounded-full border-2 border-white/70
                      pointer-events-none shadow-[0_0_0_1px_rgba(0,0,0,.6)]"></div>
          <div id="keepOutline"
               class="absolute border-2 border-amber-400 pointer-events-none transition-all duration-500 ease-out
                      shadow-[0_0_30px_-6px_rgba(251,191,36,.6)]"></div>
        </div>

        {/*
          Split loupe. The same patch of the same image at the same zoom, with
          the ~18K negative permanently on the left and the selected format on
          the right. A side-by-side removes absolute judgement entirely: nobody
          can rate texture in isolation, everybody can see which half is softer.
        */}
        <figure id="loupe"
          class="absolute right-2 top-2 w-[168px] sm:w-[232px] cursor-grab active:cursor-grabbing
                 touch-none select-none rounded-md overflow-hidden border border-zinc-600
                 bg-zinc-950 shadow-lg">
          <div class="relative flex h-[66px] sm:h-[92px]">

            {/* Reference: always the negative, never altered. */}
            <div class="relative w-1/2 overflow-hidden">
              <div id="refInner" class="absolute top-0 left-0 origin-top-left">
                <Scene idPrefix="loupeRef" />
              </div>
              <span class="absolute inset-x-0 top-0 px-1 bg-zinc-950/80 text-center
                           text-[8px] sm:text-[9px] font-mono text-cyan-300 truncate">~18K {L.loupeRef}</span>
            </div>

            <div class="w-px bg-zinc-500 shrink-0"></div>

            {/* Selected format: softened, and overlaid with its sampling structure. */}
            <div class="relative w-1/2 overflow-hidden">
              <div id="loupeInner" class="absolute top-0 left-0 origin-top-left">
                <Scene idPrefix="loupeSel" />
              </div>
              <canvas id="pixCanvas" class="absolute inset-0 w-full h-full hidden"></canvas>
              <svg id="loupeGrain" class="absolute inset-0 w-full h-full pointer-events-none mix-blend-overlay"
                   aria-hidden="true">
                <filter id="grainFilter">
                  <feTurbulence id="grainNoise" type="fractalNoise" baseFrequency="0.55"
                                numOctaves="4" stitchTiles="stitch" />
                </filter>
                <rect id="grainRect" width="100%" height="100%" filter="url(#grainFilter)" opacity="0.5" />
              </svg>
              <span id="loupeLabel"
                    class="absolute inset-x-0 top-0 px-1 bg-zinc-950/80 text-center
                           text-[8px] sm:text-[9px] font-mono text-amber-300 truncate"></span>
            </div>
          </div>

          <figcaption id="loupeCaption"
            class="px-1.5 py-0.5 bg-zinc-950 border-t border-zinc-700
                   text-[7px] sm:text-[8px] text-zinc-500 text-center truncate">{L.loupeCompare}</figcaption>
        </figure>

        <p id="lossTag"
           class="absolute bottom-1.5 left-1/2 -translate-x-1/2 text-[10px] font-mono px-2 py-1 rounded
                  bg-zinc-950/85 border border-zinc-800 max-w-[92%] text-center leading-tight"></p>
      </div>

      <button type="button" data-step="-1" aria-label={L.prevFormat}
        class="step-btn absolute left-1 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full grid place-items-center
               bg-zinc-950/80 border border-zinc-700 text-zinc-300 backdrop-blur
               hover:bg-zinc-900 hover:text-cyan-300 transition cursor-pointer">&#8249;</button>
      <button type="button" data-step="1" aria-label={L.nextFormat}
        class="step-btn absolute right-1 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full grid place-items-center
               bg-zinc-950/80 border border-zinc-700 text-zinc-300 backdrop-blur
               hover:bg-zinc-900 hover:text-cyan-300 transition cursor-pointer">&#8250;</button>
    </div>

    {/* Compact readout strip: the two losses side by side, never merged. */}
    <div class="shrink-0 grid grid-cols-4 gap-1.5 sm:gap-2">
      <div class="bg-zinc-900/60 border border-zinc-800 rounded px-2 py-1.5">
        <p class="text-[9px] uppercase tracking-wider text-zinc-500 truncate">{L.framing}</p>
        <p id="statKept" class="text-[15px] sm:text-lg font-mono text-cyan-300 tabular-nums leading-tight">{pct(initial.kept)}%</p>
        <span class="mt-1 block h-1 rounded-full bg-zinc-800 overflow-hidden">
          <span id="barKept" class="bar block h-full rounded-full transition-all duration-500" style={`width:${pct(initial.kept)}%`}></span>
        </span>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded px-2 py-1.5">
        <p class="text-[9px] uppercase tracking-wider text-zinc-500 truncate">{L.detail}</p>
        <p id="statDetail" class="text-[15px] sm:text-lg font-mono text-amber-300 tabular-nums leading-tight">{pct(initial.detail)}%</p>
        <span class="mt-1 block h-1 rounded-full bg-zinc-800 overflow-hidden">
          <span id="barDetail" class="bar-detail block h-full rounded-full transition-all duration-500" style={`width:${pct(initial.detail)}%`}></span>
        </span>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded px-2 py-1.5">
        <p class="text-[9px] uppercase tracking-wider text-zinc-500 truncate">{L.resolution}</p>
        <p id="statRes" class="text-[15px] sm:text-lg font-mono text-zinc-200 tabular-nums leading-tight">{initial.resolution}</p>
        <p class="text-[9px] text-zinc-600 mt-1 truncate">{L.vsNegative} ~18K</p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded px-2 py-1.5">
        <p class="text-[9px] uppercase tracking-wider text-zinc-500 truncate">{L.cutFrom}</p>
        <p id="statAxis" class="text-[12px] sm:text-[13px] text-zinc-300 truncate leading-tight mt-1">—</p>
      </div>
    </div>

    {/*
      The headline sits here, always visible. It used to be behind the dialog,
      which meant the scarcity story — the actual point of the page — went unread.
    */}
    <div class="shrink-0 flex items-start gap-2">
      <span class="shrink-0 mt-[3px] w-1 h-3.5 rounded-full bg-amber-400"></span>
      <p id="fHeadline" class="text-[12px] sm:text-[13px] leading-snug text-zinc-300">{initial.headline}</p>
      <button type="button" id="whyBtnInline"
        class="shrink-0 ml-auto text-[11px] text-cyan-400/80 hover:text-cyan-300 underline
               underline-offset-2 whitespace-nowrap cursor-pointer">{L.more}</button>
    </div>
  </section>
</main>

{/* ── "Why" dialog: keeps the long-form context off the main view ──
     A native <dialog> gets focus trapping, Esc-to-close and the backdrop for
     free — no library, no scroll added to the page underneath. */}
<dialog id="whyDialog"
  class="backdrop:bg-black/70 bg-zinc-900 border border-zinc-700 rounded-xl p-0
         w-[min(92vw,640px)] max-h-[85dvh] text-zinc-200">
  <div class="sticky top-0 flex items-center justify-between gap-4 px-5 py-3
              border-b border-zinc-800 bg-zinc-900">
    <h3 class="text-sm font-semibold text-zinc-100">{L.whyTitle}</h3>
    <button type="button" id="whyClose" aria-label={L.close}
      class="w-7 h-7 rounded-full border border-zinc-700 text-zinc-400 grid place-items-center
             hover:text-zinc-100 transition cursor-pointer">&times;</button>
  </div>

  <div class="px-5 py-4 space-y-4 overflow-y-auto">

    {/* Define the term before using it: every number on the page is stated
         relative to "the negative", which is not everyday vocabulary. */}
    <section class="rounded-lg border border-cyan-400/25 bg-cyan-400/[.04] p-3.5">
      <h4 class="text-[13px] font-semibold text-cyan-300">{L.negativeTermTitle}</h4>
      {L.negativeTermBody.map((para) => (
        <p class="text-[13px] leading-relaxed text-zinc-300 mt-2">{para}</p>
      ))}

      {/* A miniature of the two shapes, so the word lands visually too. */}
      <div class="mt-3 flex items-end gap-3">
        <div class="text-center">
          <div class="w-[54px] h-[38px] border-2 border-cyan-400 rounded-[2px] bg-cyan-400/10"></div>
          <p class="text-[9px] font-mono text-cyan-300 mt-1">1.43:1</p>
        </div>
        <div class="text-center">
          <div class="w-[54px] h-[23px] border-2 border-dashed border-amber-400/70 rounded-[2px]"></div>
          <p class="text-[9px] font-mono text-amber-300/90 mt-1">2.39:1</p>
        </div>
        <p class="text-[11px] text-zinc-500 leading-snug flex-1">{L.negativeTermAside}</p>
      </div>
    </section>

    {FACTS.map((f) => (
      <div class="flex gap-3.5">
        <span class="shrink-0 w-20 text-right font-mono text-cyan-300 text-[15px] leading-tight">{f.stat}</span>
        <div class="min-w-0">
          <p class="text-[12px] uppercase tracking-wider text-zinc-500">{f.label}</p>
          <p class="text-[13px] leading-relaxed text-zinc-400 mt-0.5">{f.body}</p>
        </div>
      </div>
    ))}

    <p class="text-[11px] leading-relaxed text-zinc-600 border-t border-zinc-800 pt-3.5">{L.disclaimer}</p>
  </div>
</dialog>

<style>
  .band {
    background:
      repeating-linear-gradient(45deg, rgba(251,191,36,.13) 0 6px, transparent 6px 12px),
      rgba(9,9,11,.84);
    transition: all .5s ease-out;
  }
  .bar { background: linear-gradient(90deg, #22d3ee, #0891b2); }
  .bar-detail { background: linear-gradient(90deg, #fbbf24, #b45309); }

  .format-btn[aria-checked='true'] {
    background: rgba(34,211,238,.08);
    border-color: rgba(34,211,238,.45);
  }
  .format-btn[aria-checked='true'] .bar { background: linear-gradient(90deg, #fbbf24, #f59e0b); }
  .chip[aria-checked='true'] { background: rgba(34,211,238,.12); border-color: #22d3ee; }
  .chip[aria-checked='true'] span { color: #67e8f9; }

  .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }

  #viewport, #negativeBox { transition: width .5s ease-out, height .5s ease-out; }

  @media (hover: none) { .step-btn { width: 2.5rem; height: 2.5rem; } }

  /* In landscape on a phone there is no vertical room for the readout strip;
     the image is what matters, so the numbers go. */
  @media (max-height: 430px) and (orientation: landscape) {
    #fHeadline, #whyBtnInline { display: none; }
  }
</style>

<script is:inline define:vars={{ RELEASE_FORMATS, SOURCE_RATIO, DEFAULT_FORMAT_ID, STR }}>
  const $ = (id) => document.getElementById(id);
  // Where the loupe is looking, as a fraction of the frame. Mutable: the user
  // can drag the loupe to inspect anywhere, since one fixed patch cannot be
  // interesting for every format.
  let FOCUS_X = 0.44;
  let FOCUS_Y = 0.56;   // ship, horizon and sail base — the busiest region
  const all = (sel) => Array.from(document.querySelectorAll(sel));

  /** Kept fraction per axis. One is always 1 — you crop, never stretch. */
  const SOURCE_DETAIL_PX = 18000;
  const detailFraction = (px) => Math.min(1, px / SOURCE_DETAIL_PX);

  function cropFractions(target) {
    return target >= SOURCE_RATIO
      ? { width: 1, height: SOURCE_RATIO / target }
      : { width: target / SOURCE_RATIO, height: 1 };
  }

  let index = RELEASE_FORMATS.findIndex((f) => f.id === DEFAULT_FORMAT_ID);

  /**
   * Rasterize the scene once so the digital half can be genuinely resampled.
   * The SVG is serialized to a data URI; nothing external is fetched, so the
   * canvas stays untainted and this works offline.
   */
  let sceneImg = null;
  let sceneReady = false;
  (function loadScene() {
    const svg = document.getElementById('loupeSel-root');
    if (!svg) return;
    const clone = svg.cloneNode(true);
    clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
    clone.setAttribute('width', '1430');
    clone.setAttribute('height', '1000');
    const src = 'data:image/svg+xml;charset=utf-8,' +
      encodeURIComponent(new XMLSerializer().serializeToString(clone));
    sceneImg = new Image();
    sceneImg.onload = () => { sceneReady = true; render(); };
    sceneImg.src = src;
  })();

  /**
   * Draw the same patch the reference half shows, but resampled to the
   * format's pixel count and scaled back up with smoothing off — which is
   * what a low-resolution image actually looks like.
   */
  function drawPixelated(canvas, w, h, negW, negH, ZOOM, detailPx) {
    if (!sceneReady) return;
    const dpr = Math.min(2, window.devicePixelRatio || 1);
    canvas.width = Math.max(1, Math.round(w * dpr));
    canvas.height = Math.max(1, Math.round(h * dpr));
    const ctx = canvas.getContext('2d');

    // Blocks across the visible half. Deliberately exaggerated: true pixels at
    // this magnification would be invisible, and the point is relative
    // coarseness between formats.
    const blocks = Math.max(4, Math.round(detailPx / 260));
    const small = document.createElement('canvas');
    small.width = blocks;
    small.height = Math.max(1, Math.round(blocks * (h / w)));

    // Same framing maths as the DOM half, so both sides show the same spot.
    const sw = negW * ZOOM, sh = negH * ZOOM;
    const tx = w / 2 - FOCUS_X * sw;
    const ty = h / 2 - FOCUS_Y * sh;
    const k = blocks / w;

    const sctx = small.getContext('2d');
    sctx.drawImage(sceneImg, tx * k, ty * k, sw * k, sh * k);

    ctx.imageSmoothingEnabled = false;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(small, 0, 0, canvas.width, canvas.height);
  }

  function render() {
    const current = RELEASE_FORMATS[index];
    const stage = $('stage');
    const c = cropFractions(current.ratio);
    const kept = c.width * c.height;

    // The negative is the constant: it always fits the stage, and crops shrink
    // inside it. If the crop rescaled to fill, the loss would be invisible.
    // getBoundingClientRect, not clientWidth: it reports fractional, post-layout
    // values, and clientWidth rounds — enough to push the frame off-centre.
    const box = stage.getBoundingClientRect();
    if (box.width < 2 || box.height < 2) return; // not laid out yet

    const pad = box.width < 480 ? 16 : 32;
    const maxW = Math.max(40, box.width - pad);
    const maxH = Math.max(40, box.height - pad);
    let negW = maxW, negH = negW / SOURCE_RATIO;
    if (negH > maxH) { negH = maxH; negW = negH * SOURCE_RATIO; }

    const keepW = negW * c.width;
    const keepH = negH * c.height;
    const offX = (negW - keepW) / 2;
    const offY = (negH - keepH) / 2;

    const negBox = $('negativeBox');
    negBox.style.width = `${negW}px`;
    negBox.style.height = `${negH}px`;

    const vp = $('viewport');
    vp.style.width = `${negW}px`;
    vp.style.height = `${negH}px`;

    $('bandTop').style.height = `${offY}px`;
    $('bandBottom').style.height = `${offY}px`;
    $('bandLeft').style.width = `${offX}px`;
    $('bandRight').style.width = `${offX}px`;

    const outline = $('keepOutline');
    outline.style.display = kept < 1 ? 'block' : 'none';
    outline.style.left = `${offX}px`;
    outline.style.top = `${offY}px`;
    outline.style.width = `${keepW}px`;
    outline.style.height = `${keepH}px`;

    const detail = detailFraction(current.detailPx);
    const detailPct = Math.round(detail * 100);
    const lostPct = Math.round((1 - kept) * 100);
    $('fName').textContent = current.name;
    $('fVenue').textContent = current.venue;
    $('fRatio').textContent = current.ratioLabel;
    $('fHeadline').textContent = current.headline;
    $('statRes').textContent = current.resolution;
    $('statKept').textContent = `${Math.round(kept * 100)}%`;
    $('statDetail').textContent = `${detailPct}%`;
    $('barKept').style.width = `${Math.round(kept * 100)}%`;
    $('barDetail').style.width = `${detailPct}%`;
    $('statAxis').textContent =
      kept === 1 ? STR.cutNothing : current.ratio >= SOURCE_RATIO ? STR.cutVertical : STR.cutHorizontal;

    // ── Split loupe ──────────────────────────────────────────────────
    // Both halves show the same patch at the same zoom, so the only difference
    // is the treatment applied to the right one.
    const loupe = $('loupe');
    const halfW = loupe.clientWidth / 2;
    const loupeH = loupe.querySelector('canvas').parentElement.clientHeight;
    const ZOOM = 2.4;

    const placeHalf = (el) => {
      el.style.width = `${negW * ZOOM}px`;
      el.style.height = `${negH * ZOOM}px`;
      el.style.transform =
        `translate(${halfW / 2 - FOCUS_X * negW * ZOOM}px, ${halfW / 2 - FOCUS_Y * negH * ZOOM}px)`;
    };
    placeHalf($('refInner'));
    placeHalf($('loupeInner'));

    // Softness stands in for lost resolution on film; digital gets real blocks.
    const ratio = SOURCE_DETAIL_PX / current.detailPx;
    const blur = Math.max(0, (ratio - 1) * 0.5);

    const grain = $('loupeGrain');
    const canvas = $('pixCanvas');
    const sel = $('loupeInner');

    if (current.isFilm) {
      // Film: no sampling grid exists, so detail is lost as softness and grain.
      canvas.classList.add('hidden');
      sel.style.display = '';
      sel.style.filter = blur ? `blur(${blur.toFixed(2)}px)` : 'none';

      // The negative compared against itself must be pixel-identical. Grain is
      // drawn with mix-blend-overlay, so leaving it on at full strength tinted
      // the right half and made "both sides are the same" visibly false.
      if (current.detailPx >= SOURCE_DETAIL_PX) {
        grain.style.display = 'none';
      } else {
        grain.style.display = 'block';
        const freq = Math.max(0.16, 1.4 * (current.detailPx / SOURCE_DETAIL_PX));
        $('grainNoise').setAttribute('baseFrequency', freq.toFixed(3));
        $('grainRect').setAttribute('opacity',
          (0.18 + 0.32 * (1 - current.detailPx / SOURCE_DETAIL_PX)).toFixed(2));
      }
      $('loupeLabel').textContent = STR.loupeFilm.replace('{px}', current.resolution);
    } else {
      // Digital: the image is genuinely resampled onto a fixed pixel grid, so
      // it is drawn blocky rather than having a mesh laid over a sharp image.
      // The mesh looked like graph paper; low resolution looks like this.
      grain.style.display = 'none';
      sel.style.display = 'none';
      canvas.classList.remove('hidden');
      drawPixelated(canvas, halfW, loupeH, negW, negH, ZOOM, current.detailPx);
      $('loupeLabel').textContent = STR.loupeDigital.replace('{px}', current.resolution);
    }

    // When the negative IS the selection, say so rather than showing two
    // identical halves and letting it look like a rendering bug.
    const mark = $('focusMark');
    mark.style.left = `${offX + FOCUS_X * negW * c.width}px`;
    mark.style.top = `${offY + FOCUS_Y * negH * c.height}px`;

    $('loupeCaption').textContent = current.detailPx >= SOURCE_DETAIL_PX
      ? STR.loupeSame : STR.loupeCompare;

    const tag = $('lossTag');
    // Three states, because "full framing" is not the same as "lossless".
    if (kept === 1 && detail === 1) {
      tag.textContent = STR.fullNegative;
      tag.style.color = '#22d3ee';
    } else if (kept === 1) {
      tag.textContent = STR.detailOnly.replace('{d}', detailPct);
      tag.style.color = '#fcd34d';
    } else {
      tag.textContent = STR.lossTag.replace('{p}', lostPct).replace('{d}', detailPct);
      tag.style.color = '#fcd34d';
    }

    all('.format-btn').forEach((b) =>
      b.setAttribute('aria-checked', String(b.dataset.format === current.id)));
    document.querySelector(`.chip[data-format="${current.id}"]`)
      ?.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
  }

  const select = (i) => { index = (i + RELEASE_FORMATS.length) % RELEASE_FORMATS.length; render(); };

  all('.format-btn').forEach((btn) =>
    btn.addEventListener('click', () =>
      select(RELEASE_FORMATS.findIndex((f) => f.id === btn.dataset.format))));
  all('.step-btn').forEach((btn) =>
    btn.addEventListener('click', () => select(index + Number(btn.dataset.step))));

  // Drag the loupe to inspect anywhere in the frame. One fixed patch cannot
  // be the interesting one for every format, and the flat sky reads as a bug.
  (function enableLoupeDrag() {
    const loupe = $('loupe');
    let dragging = false, lastX = 0, lastY = 0;

    const onDown = (e) => {
      dragging = true;
      lastX = e.clientX; lastY = e.clientY;
      loupe.setPointerCapture?.(e.pointerId);
      e.preventDefault();
      e.stopPropagation();   // the stage listens for swipes; this is not one
    };

    const onMove = (e) => {
      if (!dragging) return;
      const stage = $('stage');
      const box = stage.getBoundingClientRect();
      // Dragging right should reveal what is to the right, so the focus moves
      // with the pointer rather than against it.
      const ZOOM = 2.4;
      FOCUS_X = Math.min(1, Math.max(0, FOCUS_X - (e.clientX - lastX) / (box.width * ZOOM)));
      FOCUS_Y = Math.min(1, Math.max(0, FOCUS_Y - (e.clientY - lastY) / (box.height * ZOOM)));
      lastX = e.clientX; lastY = e.clientY;
      e.stopPropagation();
      render();
    };

    const onUp = (e) => {
      dragging = false;
      loupe.releasePointerCapture?.(e.pointerId);
    };

    loupe.addEventListener('pointerdown', onDown);
    loupe.addEventListener('pointermove', onMove);
    loupe.addEventListener('pointerup', onUp);
    loupe.addEventListener('pointercancel', onUp);
    // Swallow touch gestures so dragging the loupe never changes format.
    ['touchstart', 'touchmove', 'touchend'].forEach((t) =>
      loupe.addEventListener(t, (e) => e.stopPropagation(), { passive: true }));
  })();

  // Swipe, gated to horizontal intent so vertical gestures still behave.
  let startX = 0, startY = 0;
  const stage = $('stage');
  stage.addEventListener('touchstart', (e) => {
    startX = e.touches[0].clientX; startY = e.touches[0].clientY;
  }, { passive: true });
  stage.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    if (Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy) * 1.5) select(index + (dx < 0 ? 1 : -1));
  }, { passive: true });

  const dlg = $('whyDialog');
  [$('whyBtnDesktop'), $('whyBtnMobile'), $('whyBtnInline')].forEach((b) => b?.addEventListener('click', () => dlg.showModal()));
  $('whyClose').addEventListener('click', () => dlg.close());
  // Click the backdrop (i.e. outside the dialog's own box) to dismiss.
  dlg.addEventListener('click', (e) => {
    const r = dlg.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) dlg.close();
  });

  document.addEventListener('keydown', (e) => {
    if (dlg.open) return;
    if (e.key === 'ArrowRight') select(index + 1);
    else if (e.key === 'ArrowLeft') select(index - 1);
  });

  new ResizeObserver(render).observe(stage);
  render();
</script>
