---
/**
 * Resolution chart — an optician's-eye-chart reading of detail.
 *
 * Grain frequency turned out to be a poor comparator: people judge relative
 * differences well and absolute texture badly, so "is this grain finer than the
 * last one?" is nearly unanswerable without the two side by side. Counting how
 * many rows of line pairs survive is answerable at a glance.
 *
 * Each row is a set of line pairs at a decreasing pitch. A format resolves a
 * row only if its pitch is above that format's limit; below the limit the row
 * is drawn as a flat bar, i.e. the lines have merged into grey. Both states are
 * rendered here and the client toggles between them — no DOM building at
 * runtime, and the chart is complete in the HTML without JavaScript.
 */

/** Line-pair pitch per row, coarse to fine, in viewBox units. */
export const PITCHES = [30, 18, 11, 7, 4.5, 3];

const W = 100;
const ROW_H = 7;
const GAP = 2.6;

const rows = PITCHES.map((pitch, i) => {
  const y = i * (ROW_H + GAP);
  // Half the pitch is ink, half is paper — that is what a "line pair" means.
  const bars: number[] = [];
  for (let x = 0; x + pitch / 2 <= W; x += pitch) bars.push(x);
  return { pitch, y, bars };
});

const height = rows.length * (ROW_H + GAP) - GAP;
---

<svg viewBox={`0 0 ${W} ${height}`} class="block w-full h-full" aria-hidden="true"
     preserveAspectRatio="none">
  {rows.map((row, i) => (
    <g data-row={i}>
      {/* Resolved: the individual line pairs are distinguishable. */}
      <g class="row-lines">
        {row.bars.map((x) => (
          <rect x={x} y={row.y} width={row.pitch / 2} height={ROW_H} fill="#e4e4e7" />
        ))}
      </g>
      {/* Unresolved: the same ink, averaged into flat grey. */}
      <rect class="row-merged" x="0" y={row.y} width={W} height={ROW_H} fill="#52525b" />
    </g>
  ))}
</svg>
