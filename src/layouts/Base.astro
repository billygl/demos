---
import '../styles/global.css';
import { href } from '../lib/url';

interface Props {
  title: string;
  description: string;
  /** Show the "all demos" back-link. Off on the index itself. */
  backLink?: boolean;
  /** Small mono badge in the header, e.g. a demo's aspect ratio. */
  badge?: string;
}

const { title, description, backLink = true, badge } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#09090b" />
  <link rel="icon" href={href('/favicon.svg')} type="image/svg+xml" />
</head>

<body class="min-h-screen text-zinc-200 flex flex-col">
  {backLink && (
    <header class="border-b border-zinc-800/80 bg-zinc-950/70 backdrop-blur sticky top-0 z-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-3">
        {badge && (
          <div class="w-8 h-8 shrink-0 rounded bg-cyan-400/10 border border-cyan-400/40 grid place-items-center text-cyan-400 text-[10px] font-mono font-bold tracking-tighter">
            {badge}
          </div>
        )}
        <div class="min-w-0">
          <h1 class="text-sm sm:text-base font-semibold tracking-tight text-zinc-100 truncate">{title}</h1>
          <p class="text-[11px] text-zinc-500 truncate">{description}</p>
        </div>
        <a href={href('/')} class="ml-auto shrink-0 text-[11px] text-zinc-500 hover:text-cyan-400 transition">
          &larr; all demos
        </a>
      </div>
    </header>
  )}

  <slot />

  <footer class="mt-auto max-w-7xl mx-auto w-full px-4 sm:px-6 py-6 text-[11px] text-zinc-600">
    Built with Astro &middot; no client framework, no hydration cost
  </footer>
</body>
</html>
