---
import { getEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Explorer from '../../../components/imax/Explorer.astro';

const lang = 'en' as const;

const demo = await getEntry('demos', 'imax');
if (!demo) throw new Error('Missing content entry: src/content/demos/imax.md');
---

<Base
  lang={lang}
  title={demo.data.title[lang]}
  description={demo.data.blurb[lang]}
  badge={demo.data.badge}
  fullscreen
>
  <Explorer lang={lang} />
</Base>
